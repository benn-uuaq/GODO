                   <property name="styleSheet">
                    <string notr="true">/* 1. 테이블 전체 설정 */
QTableWidget {
    background-color: #FFFFFF;      /* 배경 흰색 */
    gridline-color: #D0D0D0;        /* 격자선 색상 (연한 회색) */
    border: 1px solid #AAAAAA;      /* 전체 테두리 */
    selection-background-color: #0078D7; /* 선택 시 파란색 배경 */
    selection-color: #FFFFFF;       /* 선택 시 흰색 글자 */
    font-size: 12px;                /* 글자 크기 */
}

/* 2. 헤더 (맨 윗줄 제목 칸) */
QHeaderView::section {
    background-color: #F0F0F0;      /* 헤더 배경 (아주 연한 회색) */
    color: #000000;                 /* 헤더 글자 검정 */
    padding: 2px;                   /* 내부 여백 */
    border: 1px solid #D0D0D0;      /* 헤더 칸 구분선 */
    border-bottom: 2px solid #888888; /* 헤더 아래쪽만 진하게 (구분감) */
    font-weight: bold;              /* 글자 굵게 */
}

/* 3. 왼쪽 위 모서리 (빈 공간) */
QTableCornerButton::section {
    background-color: #F0F0F0;
    border: 1px solid #D0D0D0;
    border-bottom: 2px solid #888888;
}

