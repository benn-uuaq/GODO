                         <property name="styleSheet">
                          <string notr="true">/* 기본 상태 (여기에 크기를 고정하는 것이 좋습니다) */
#cell_1_pose_btn {
	min-width: 100px;
	max-width: 100px;
	min-height: 100px;
	max-height: 100px;
}

#cell_1_pose_btn:enabled {
	color: rgb(255, 255, 255);
	background-color: #00A5E5;
	font: bold 16pt &quot;Arial&quot;;
	border: 1px solid rgb(0, 0, 0);
	/* 핵심: 너비(100px)의 절반인 50px로 설정 */
	border-radius: 50px; 
	border-bottom: 3px solid #019cda;
	border-right: 3px solid #019cda;
	margin-top: 4px;                 
	margin-bottom: 4px;
}

#cell_1_pose_btn:hover {
	background-color: #019cda;
	border-radius: 50px; /* 여기도 50px로 변경 */
	border-bottom: 3px solid #0199d5;
	border-right: 3px solid #0199d5;
	margin-top: 4px;                 
	margin-bottom: 4px;
}

#cell_1_pose_btn:checked {
	background-color: #6ac529;
	border-radius: 50px; /* 여기도 50px로 변경 */
	border-top: 3px solid #439608;
	border-left: 3px solid #439608;
	margin-top: 6px;
	margin-bottom: 6px;
}

#cell_1_pose_btn:disabled {
	color: #000000;
	background-color: #c8c8c8;
	font: bold 16pt &quot;Arial&quot;;
	border: 1px solid #000000;
	border-radius: 50px; /* 여기도 50px로 변경 */
	border-bottom: 3px solid #686868;
	border-right: 3px solid #686868;
	margin-top: 4px;                 
	margin-bottom: 4px;
}</string>
